# --- Covert (Zama FHEVM) deployment ---
# Sepolia RPC (the FHEVM coprocessor + KMS live on Sepolia)
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
# Deployer private key (0x-prefixed). Keep secret. This wallet becomes the Employer (admin).
DEPLOYER_PK=
# For `npm run verify` (Etherscan contract verification)
ETHERSCAN_API_KEY=

# --- optional: reuse an already-deployed confidential USDT instead of deploying the mock ---
# Official Sepolia cUSDT mock from Zama's Wrappers Registry (ERC-7984).
# Leave blank to deploy a fresh ConfidentialMockToken for the demo.
CUSDT_ADDRESS=

# --- seed script demo wallets (scripts/seed.ts) ---
# Three test wallets used for the demo (S-03). Comma-free, one each.
EMPLOYEE_1=
EMPLOYEE_2=
EMPLOYEE_3=
AUDITOR_1=
